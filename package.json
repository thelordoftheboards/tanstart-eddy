{
  "name": "tanstart-eddy",
  "version": "0.0.45",
  "private": false,
  "type": "module",
  "author": {
    "name": "Alexander C",
    "url": "https://github.com/thelordoftheboards"
  },
  "packageManager": "bun@1.3.11",
  "license": "unlicense",
  "scripts": {
    "dev": "vite dev --strictPort --port 8088",
    "dev-lt": "concurrently --names 'vi,lt' --prefix-colors 'blue,yellow' --prefix '{time}-{pid} {name}' '. ./devconfig/localtunnel-settings.sh && bun dev' 'sleep 3 && bun lt' --restart-tries 3 --restart-after exponential 'exit 1'",
    "lt": ". ./devconfig/localtunnel-settings.sh && ./node_modules/.bin/lt --port 8088 --subdomain ${LOCALTUNNEL_SUBDOMAIN} --print-requests",
    "make": "bun run clean && bun run format && bun run build && bun run post-build-actions",
    "build": "vite build",
    "build:bump": "bun pm version patch --no-git-tag-version",
    "post-build-actions": "./devtools/post-build-actions.sh",
    "preview": "vite preview",
    "start": "cp .env ./.output/server/.env && cd ./.output/server/ && export NODE_ENV=production && bun index.mjs",
    "start-lt": "concurrently --names 'vi,lt' --prefix-colors 'blue,yellow' --prefix '{time}-{pid} {name}' '. ./devconfig/localtunnel-settings.sh && bun start' 'sleep 3 && bun lt' --restart-tries 3 --restart-after exponential 'exit 1'",
    "format": "biome format --write",
    "lint": "biome lint",
    "check:fix": "biome check --write",
    "check-types": "tsc --noEmit",
    "check": "biome check && bun check-types",
    "db:generate": "drizzle-kit generate --config drizzle.config.ts && bun format",
    "db:push": "bun --env-file=.env drizzle-kit push",
    "ui": "bunx shadcn@latest",
    "auth:secret": "bunx @better-auth/cli@latest secret",
    "auth:generate": "bunx @better-auth/cli@latest generate --config ./src/lib/auth/auth.ts --y --output ./src/lib/db/schema/auth.schema.ts && biome format --write ./src/lib/db/schema/auth.schema.ts",
    "docker:setup": ". ./devconfig/docker-settings.sh && docker network create \"${IMAGE_NAME}-development-network\"",
    "docker:build": "./devtools/docker-build.sh",
    "docker:run": ". ./devconfig/docker-settings.sh && docker rm -f \"${IMAGE_NAME}-standalone-app\" || true && docker run -d -p 8088:8088 --env-file .env --network \"${IMAGE_NAME}-development-network\" --name \"${IMAGE_NAME}-standalone-app\" \"${IMAGE_NAME}\"",
    "compose:db:up": "docker compose --env-file devconfig/standalone-db.env -f docker/standalone-db-compose.yaml up -d",
    "compose:db:down": "docker compose --env-file devconfig/standalone-db.env -f docker/standalone-db-compose.yaml down -v",
    "compose:garage:up": "docker compose --env-file devconfig/standalone-garage.env -f docker/standalone-garage-compose.yaml up -d",
    "compose:garage:down": "docker compose --env-file devconfig/standalone-garage.env -f docker/standalone-garage-compose.yaml down -v",
    "compose:full:up": "docker compose --env-file devconfig/full.env -f docker/full-compose.yaml up -d",
    "compose:full:down": "docker compose --env-file devconfig/full.env -f docker/full-compose.yaml down -v",
    "docker:remove": ". ./devconfig/docker-settings.sh && docker network rm \"${IMAGE_NAME}-development-network\"",
    "clean": "rm -rf .mastra && rm -rf .nitro && rm -rf .tanstack && rm -rf .output && rm -rf node_modules/.vite",
    "prepare": "husky"
  },
  "dependencies": {
    "@base-ui/react": "1.3.0",
    "@dnd-kit/core": "6.3.1",
    "@dnd-kit/modifiers": "9.0.0",
    "@hookform/resolvers": "5.2.2",
    "@react-email/components": "1.0.12",
    "@rolldown/plugin-babel": "0.2.2",
    "@t3-oss/env-core": "0.13.11",
    "@tabler/icons-react": "3.41.1",
    "@tanstack/react-form": "1.29.0",
    "@tanstack/react-query": "5.99.0",
    "@tanstack/react-router": "1.167.4",
    "@tanstack/react-router-ssr-query": "1.166.11",
    "@tanstack/react-start": "1.166.16",
    "@turf/buffer": "7.3.4",
    "@turf/circle": "7.3.4",
    "@turf/turf": "7.3.4",
    "@vitejs/plugin-react": "6.0.1",
    "async-retry": "1.3.3",
    "better-auth": "1.6.2",
    "class-variance-authority": "0.7.1",
    "clsx": "2.1.1",
    "cmdk": "1.1.1",
    "date-fns": "4.1.0",
    "drizzle-orm": "0.45.2",
    "embla-carousel-react": "8.6.0",
    "eventemitter3": "5.0.4",
    "framer-motion": "12.38.0",
    "input-otp": "1.4.2",
    "libphonenumber-js": "1.12.41",
    "lucide-react": "1.8.0",
    "maplibre-gl": "5.22.0",
    "next-themes": "0.4.6",
    "nitro": "3.0.260311-beta",
    "postgres": "3.4.9",
    "react": "19.2.5",
    "react-day-picker": "9.14.0",
    "react-dom": "19.2.5",
    "react-hook-form": "7.72.1",
    "react-image-file-resizer": "0.4.8",
    "react-map-gl": "8.1.1",
    "react-resizable-panels": "4.9.0",
    "redaxios": "0.5.1",
    "resend": "6.10.0",
    "shadcn": "4.2.0",
    "sonner": "2.0.7",
    "tailwind-merge": "3.5.0",
    "ua-parser-js": "2.0.9",
    "uuid": "13.0.0",
    "vaul": "1.1.2",
    "vite": "8.0.8",
    "zod": "4.3.6"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.11",
    "@tailwindcss/vite": "4.2.2",
    "@tanstack/devtools-vite": "0.6.0",
    "@tanstack/react-devtools": "0.10.2",
    "@tanstack/react-form-devtools": "0.2.21",
    "@tanstack/react-query-devtools": "5.99.0",
    "@tanstack/react-router-devtools": "1.166.13",
    "@types/async-retry": "1.4.9",
    "@types/bun": "1.3.12",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "babel-plugin-react-compiler": "1.0.0",
    "concurrently": "9.2.1",
    "drizzle-kit": "0.31.10",
    "husky": "9.1.7",
    "localtunnel": "2.0.2",
    "tailwindcss": "4.2.2",
    "tw-animate-css": "1.4.0",
    "typescript": "6.0.2",
    "ultracite": "7.4.4"
  }
}
